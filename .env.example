# GEMINI_API_KEY: Required for Gemini AI API calls if your local setup uses it.
# Keep real API keys in a local-only env file such as .env.local.
# Do not commit actual credentials to source control.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this app is hosted.
# Use a local override for development or a deployment-specific runtime value.
APP_URL="MY_APP_URL"
